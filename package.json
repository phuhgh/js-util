{
  "name": "rc-js-util",
  "version": "3.9.0",
  "license": "MIT",
  "scripts": {
    "generate-lib": "tsc -d",
    "build": "tsc -d -p tsconfig.specs.json",
    "lint": "tslint -p tsconfig.json -c tslint.json",
