    "prepare": "npm run clean && npm run lint && npm run build && npm run test && npm run clean && npm run generate-lib",
    "test": "jasmine --config=jasmine.json"
  },
  "dependencies": {
    "rc-js-util-globals": "^0.0.2"
  },
  "devDependencies": {
    "@types/jasmine": "^3.6.6",
    "jasmine": "^3.6.4",
    "jasmine-core": "^3.6.0",
    "rc-lint-rules": "^5.0.0",
    "rimraf": "^3.0.2",
    "tslint": "^6.1.3",
    "typescript": "~4.2.3"
  },
  "private": false
}
