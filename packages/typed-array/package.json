{
  "name": "@rc-js-util/typed-array",
  "version": "1.0.0",
  "license": "MIT",
  "scripts": {
    "build": "rimraf bin && tsc -d",
    "generate-docs": "rimraf docs tmp && api-extractor run -c api-extractor.json",
    "lint": "eslint -c node_modules/rc-lint-rules/.eslintrc.js src/",
    "test": "jest ./src",
    "lib": "rimraf bin && tsc -d -p tsconfig.lib.json",
    "ci-build": "npm run build && npm run lint && npm run test && npm run lib && npm run generate-docs"
  },
  "dependencies": {
    "@rc-js-util/debug": "^1.0.0",
    "@rc-js-util/core": "^1.0.0",
    "@rc-js-util/types": "^1.0.0",
    "@rc-js-util/colors": "^1.0.0",
    "tslib": "^2.4.0"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "^7.24.2",
    "rc-lint-rules": "^6.0.1",
    "@rc-js-util/test": "^1.0.0",
    "@types/jest": "^28.1.1",
    "ts-jest": "^28.0.4",
    "jest": "^28.1.0",
    "typescript": "~4.7.3",
    "rimraf": "^3.0.2"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./bin/index.d.ts",
        "default": "./bin/index.js"
      }
    }
  },
  "sideEffects": false,
  "repository": "https://github.com/phuhgh/js-util",
  "homepage": "https://phuhgh.github.io/js-util/rc-js-util.html"
}
