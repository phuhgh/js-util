{
  "compilerOptions": {
    "importHelpers": true,
    "module": "NodeNext",
    "moduleResolution": "Node",
    "outDir": "bin/",
    "experimentalDecorators": true,
    "noImplicitReturns": true,
    "removeComments": false,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "strict": true,
    "target": "es6",
    "sourceMap": true,
    "lib": [
      "es6",
      "ES2015.Proxy",
      "ESNext"
      // WeakRef & FinalizationRegistry, not part of public sig
    ],
    "types": [
      "jest"
    ]
  },
  "include": [
    "src"
  ]
}
