{
  "compilerOptions": {
    "importHelpers": true,
    "module": "CommonJS", // todo jack: switch this to es if possible
    "outDir": "bin/",
    "experimentalDecorators": true,
    "noImplicitReturns": true,
    "removeComments": false,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "strict": true,
    "target": "es6",
    "sourceMap": true,
    "lib": [
      "es6"
    ],
    "types": [
      "jest"
    ]
  },
  "include": [
    "src"
  ]
}