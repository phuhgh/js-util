{
  "compilerOptions": {
    "importHelpers": true,
    "module": "NodeNext",
    "moduleResolution": "Node",
    "outDir": "bin/",
    "experimentalDecorators": true,
    "noImplicitReturns": true,
    "removeComments": false,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "strict": true,
    "target": "es6", // todo jack: check that this isn't mangling generators
    "sourceMap": true,
    "lib": [
      "es6",
      "ES2017.String"
    ],
    "types": [
      "jest"
    ]
  },
  "include": [
    "src"
  ]
}