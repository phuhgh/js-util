{
  "compilerOptions": {
    "importHelpers": true,
    "module": "CommonJS",
    "outDir": "bin/",
    "experimentalDecorators": true,
    "noImplicitReturns": true,
    "removeComments": false,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "strict": true,
    "target": "es6",
    "sourceMap": true,
    "baseUrl": ".",
    "lib": [
      "es6"
    ],
    "types": [
      "jest"
    ],
    "paths": {
      "asan-test-module": ["cpp/build/"],
      "safe-heap-test-module": ["cpp/build/"]
    }
  },
  "include": [
    "src"
  ]
}